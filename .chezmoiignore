# Manage .bashrc only on Android/Termux and Linux for now. Other hosts keep
# their host-specific .bashrc until branches are added to dot_bashrc.tmpl.
{{ if and (ne .chezmoi.os "android") (ne .chezmoi.os "linux") }}
.bashrc
{{ end }}

# Manage .zshrc only where zsh is installed.
{{ if not (lookPath "zsh") }}
.zshrc
{{ end }}

# SwiftBar is macOS-only
{{ if ne .chezmoi.os "darwin" }}
.config/swiftbar/**
{{ end }}

# Ignore the age private key backup (if any)
key.txt.age

# Ignore documentation
README.md

# Ignore internal scripts and secret source files
scripts/
secrets/
