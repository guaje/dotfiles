# IU VPN SwiftBar/OpenConnect configuration
VPN_HOST="vpn.uits.iu.edu"
# Optional. Leave empty to have openconnect-saml prompt for the username.
# Or run with: VPN_USER=your_username ./connect.sh
VPN_USER="${VPN_USER:-}"
OPENCONNECT_SAML="$HOME/.local/bin/openconnect-saml"
OPENCONNECT="$(command -v openconnect || true)"
SERVERCERT_PIN="pin-sha256:t61VQr4qD7R08K2kPP7JGWeZZkcIpBCOJs3orbawVz8="
LOG_FILE="$HOME/Library/Logs/swiftbar-iu-vpn.log"
