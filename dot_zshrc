## SOFTWARE SETUP

# Pi Setup
alias pi="$HOME/.pi/agent/scripts/pi-launch.sh"

# PyEnv Setup
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init -)"

# VirtualEnvWrapper Setup
export WORKON_HOME=$HOME/.virtualenvs
#export VIRTUALENVWRAPPER_PYTHON=$PYENV_ROOT/versions/3.13.5/bin/python3
#export VIRTUALENVWRAPPER_PYTHON=$PYENV_ROOT/shims/python3
#export PROJECT_HOME=$HOME/Dev
[[ -r $PYENV_ROOT/versions/3.13.5/bin/virtualenvwrapper.sh ]] && source $PYENV_ROOT/versions/3.13.5/bin/virtualenvwrapper.sh

# Starship Setup
#shell=$(echo $SHELL | sed 's/.*\///')
eval "$(starship init zsh)"
export STARSHIP_CONFIG="$HOME/.config/starship/config.toml"

# OpenStack Setup
# Cloud switcher (requires fzf). Picks a clouds.yaml under ~/.config/openstack/
# and exports OS_CLIENT_CONFIG_FILE + OS_CLOUD so the starship prompt and the
# openstack CLI target that cloud. Read-only clouds show green in the prompt,
# unrestricted red.
# Usage: os_cloud [query]   e.g.  os_cloud ro | os_cloud tra | os_cloud
os_cloud() {
  command -v fzf >/dev/null 2>&1 || { echo "os_cloud: fzf not found" >&2; return 1; }
  local f
  f=$(ls "$HOME/.config/openstack/"*.yaml 2>/dev/null | fzf --query="${1:-}" --select-1 --exit-0)
  [ -n "$f" ] && { export OS_CLIENT_CONFIG_FILE="$f"; export OS_CLOUD=openstack; echo "→ $(basename "$f")"; }
}

