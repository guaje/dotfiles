{{- /* chezmoi:template */ -}}
{
  "defaultModel": "gpt-5.5",
  "defaultProvider": "openai-codex",
  "defaultThinkingLevel": "high",
  "enabledModels": [
    "openai-codex/gpt-5.5",
    "reallms-dev/GLM-5.2",
    "kelley/Kimi-K2.6",
    "reallms/gpt-oss-120b",
    "reallms/gemma-4-31B-it",
    "reallms/Qwen3-Coder-Next"
  ],
  "extensions": [
    "-extensions/google-search.ts",
    "-extensions/scoped-limits.ts",
    "extensions/subagent/index.ts",
    "extensions/confirm-before-actions.ts",
    "extensions/model-health-check.ts",
    "extensions/native-notify.ts",
    "extensions/reload-merged-settings.ts"
  ],
  "imageGenerationProviders": {
    "reallms-dev": {
      "models": [
        {
          "id": "z-image-turbo",
          "name": "z-image-turbo"
        }
      ]
    }
  },
  "linkupAPIKey": "{{ (index ((secret "-d" (joinPath .chezmoi.sourceDir "secrets/private_dot_pi/private_agent/private_settings.config.json.sops.yaml") | fromYaml).data | fromYaml) "linkupAPIKey") }}",
  "managingStyle": "Empowerment",
  "subagentRosterCap": 10,
  "subagentRosterScope": "user",
  "theme": "catppuccin-mocha"
}
